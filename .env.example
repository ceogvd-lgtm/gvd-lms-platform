# ============================================================
# LMS Platform — Environment Variables Template
# Copy this file to .env and fill in the values for local dev.
# ============================================================

# ---------- App / Node ----------
NODE_ENV=development
PORT=4000

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql://lms:lms@localhost:5432/lms?schema=public

# ---------- Redis (cache + BullMQ) ----------
REDIS_URL=redis://localhost:6379

# ---------- Auth / JWT ----------
JWT_SECRET=change-me-to-a-long-random-string
REFRESH_TOKEN_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---------- Seed (pnpm --filter @lms/database db:seed) ----------
# Defaults are used if unset. ALWAYS change the password in production.
SEED_SUPER_ADMIN_EMAIL=admin@lms.local
SEED_SUPER_ADMIN_PASSWORD=Admin@123456
SEED_SUPER_ADMIN_NAME="Super Admin"

# ---------- Google OAuth2 ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ---------- SMTP (Nodemailer) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LMS Platform <no-reply@lms.local>"

# ---------- MinIO (S3-compatible storage) ----------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lms-uploads

# ---------- AI ----------
# Primary: Google Gemini (free tier gemini-2.0-flash)
GEMINI_API_KEY=
# Secondary / fallback
OPENAI_API_KEY=

# ---------- ChromaDB (vector store) ----------
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME="LMS Platform"
# Backend-side: URL of the frontend, used for email-verify & Google callback redirect.
FRONTEND_URL=http://localhost:3000

# ---------- CORS ----------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000
