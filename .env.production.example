# =========================================================
# Phase 18 — LMS Platform — PRODUCTION environment template
# ---------------------------------------------------------
# Copy this file to `.env.production` on the production host and fill
# in real values. NEVER commit `.env.production` to git.
#
# Generate strong secrets with:
#   openssl rand -base64 64
# =========================================================

# ---------- App metadata ----------
APP_VERSION=1.0.0
DOMAIN=gvdsoft.com.vn
NODE_ENV=production

# ---------- Database (Postgres 16) ----------
# Host is `postgres` inside the docker compose network.
POSTGRES_USER=lms
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=lms_prod
DATABASE_URL=postgresql://lms:CHANGE_ME_STRONG_PASSWORD@postgres:5432/lms_prod?schema=public

# ---------- Redis 7 ----------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ---------- JWT ----------
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_openssl_rand_base64_64
REFRESH_TOKEN_SECRET=CHANGE_ME_openssl_rand_base64_64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---------- URLs ----------
# Public URL the browser sees. Must match the cert in nginx.prod.conf.
NEXT_PUBLIC_API_URL=https://gvdsoft.com.vn/api/v1
APP_BASE_URL=https://gvdsoft.com.vn
FRONTEND_URL=https://gvdsoft.com.vn
ALLOWED_ORIGINS=https://gvdsoft.com.vn,https://www.gvdsoft.com.vn

# ---------- Google OAuth ----------
# Register the callback at: https://gvdsoft.com.vn/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_CALLBACK_URL=https://gvdsoft.com.vn/api/v1/auth/google/callback

# ---------- MinIO (S3-compatible) ----------
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# Publicly reachable URL — nginx proxies /minio/* to this when needed.
MINIO_PUBLIC_BASE_URL=https://gvdsoft.com.vn/minio/lms-uploads

# ---------- SMTP (Mailpit for dev, SES/Mailgun/SendGrid for prod) ----------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="GVD next-gen LMS <no-reply@gvdsoft.com.vn>"
SMTP_SECURE=false

# ---------- Google Gemini (AI assistant) ----------
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=CHANGE_ME_GEMINI_KEY
# Phase 18 — verified working models. Do NOT use 2.0-flash (429 rate limited)
# or 1.5-flash (retired 404). Override only if Google publishes replacements.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_LITE=gemini-flash-lite-latest
GEMINI_MODEL_EMBEDDING=gemini-embedding-001

# ---------- ChromaDB (vector store for RAG) ----------
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=lms_docs

# ---------- Sentry (optional — leave unset if unused) ----------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ---------- Backups ----------
# If set, scripts/backup.sh pushes daily dumps to s3://$S3_BUCKET/lms/
S3_BUCKET=
AWS_DEFAULT_REGION=ap-southeast-1
# aws CLI reads AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY from the env
# itself; fill them in if you enabled S3_BUCKET above.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
RETENTION_DAYS=30

# ---------- Post-deploy seeding (one-off) ----------
# First-run admin credentials — used only by scripts/deploy.sh --first-run.
# After the first deploy, rotate the password through the UI immediately.
SEED_SUPER_ADMIN_EMAIL=admin@gvdsoft.com.vn
SEED_SUPER_ADMIN_PASSWORD=CHANGE_ME_FIRST_LOGIN_THEN_ROTATE
