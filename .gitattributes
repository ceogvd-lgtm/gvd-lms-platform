# Enforce LF line endings for all text files in the repo.
# Windows contributors can still have CRLF in their editor if they want,
# but what gets committed is always LF.

* text=auto eol=lf

# ---- Explicitly text ----
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.html     text eol=lf
*.prisma   text eol=lf
*.env      text eol=lf
*.sql      text eol=lf

# Shell scripts MUST be LF or they break on Linux / WSL / CI
*.sh       text eol=lf
*.bash     text eol=lf
Dockerfile text eol=lf

# Config dotfiles
.gitignore       text eol=lf
.gitattributes   text eol=lf
.editorconfig    text eol=lf
.prettierrc      text eol=lf
.prettierignore  text eol=lf
.eslintrc*       text eol=lf
.env.example     text eol=lf

# Windows-only scripts should stay CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# ---- Binary (never normalize, never diff as text) ----
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.avif     binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
*.eot      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.mp4      binary
*.webm     binary
*.mp3      binary

# ---- Generated / vendored — don't show in PR diffs by default ----
pnpm-lock.yaml   -diff linguist-generated=true
package-lock.json -diff linguist-generated=true
