// ============================================================
// LMS Platform — Prisma schema (Phase 02)
// Full domain models: auth, catalog, content, assessment,
// progress, certificate, and system/audit tables.
// ------------------------------------------------------------
// Conventions:
//  - id:            cuid()
//  - Soft delete:   `isDeleted Boolean @default(false)` on Course/Lesson
//  - Timestamps:    createdAt (@default(now())) + updatedAt (@updatedAt)
//  - Table names:   snake_case via @@map
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// ENUMS
// =========================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum LessonType {
  THEORY
  PRACTICE
}

enum ContentType {
  SCORM
  XAPI
  POWERPOINT
  VIDEO
  PDF
  WEBGL
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum CourseStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  TRUE_FALSE
  FILL_BLANK
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum CertificateStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// =========================================================
// CORE — USER & CATALOG
// =========================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String
  phone         String?
  avatar        String?
  role          Role      @default(STUDENT)
  is2FAEnabled  Boolean   @default(false)
  emailVerified Boolean   @default(false)
  isBlocked     Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  instructedCourses Course[]           @relation("CourseInstructor")
  enrollments       CourseEnrollment[]
  lessonProgress    LessonProgress[]
  practiceAttempts  PracticeAttempt[]
  videoProgress     VideoProgress[]
  quizAttempts      QuizAttempt[]
  certificates      Certificate[]
  questionsCreated  QuestionBank[]     @relation("QuestionBankAuthor")
  loginLogs         LoginLog[]
  auditLogs         AuditLog[]
  notifications     Notification[]

  // Phase 14 — Student Dashboard & Learning Experience
  lessonNotes         LessonNote[]
  discussionsAuthored Discussion[]        @relation("DiscussionAuthor")
  discussionReplies   DiscussionReply[]   @relation("DiscussionReplyAuthor")
  xp                  StudentXP?

  // Phase 17 — AI Learning Assistant
  aiRecommendations   AiRecommendation[]
  aiChatMessages      AiChatMessage[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subjects     Subject[]
  questionBank QuestionBank[]

  @@map("departments")
}

model Subject {
  id           String   @id @default(cuid())
  departmentId String
  name         String
  code         String   @unique
  description  String?
  thumbnailUrl String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  courses    Course[]

  @@index([departmentId])
  @@map("subjects")
}

model Course {
  id           String       @id @default(cuid())
  subjectId    String
  instructorId String
  title        String
  description  String?
  thumbnailUrl String?
  status       CourseStatus @default(DRAFT)
  version      Int          @default(1)
  isDeleted    Boolean      @default(false)
  publishedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  subject      Subject              @relation(fields: [subjectId], references: [id])
  instructor   User                 @relation("CourseInstructor", fields: [instructorId], references: [id])
  chapters     Chapter[]
  enrollments  CourseEnrollment[]
  certificates Certificate[]
  criteria     CertificateCriteria?
  questionBank QuestionBank[]

  @@index([subjectId])
  @@index([instructorId])
  @@index([status])
  @@map("courses")
}

model Chapter {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("chapters")
}

model Lesson {
  id          String     @id @default(cuid())
  chapterId   String
  title       String
  type        LessonType
  order       Int        @default(0)
  isPublished Boolean    @default(false)
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  chapter         Chapter            @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  theoryContent   TheoryContent?
  practiceContent PracticeContent?
  attachments     LessonAttachment[]
  quizzes         Quiz[]
  progress        LessonProgress[]

  // Phase 14 — per-student notes + per-lesson Q&A threads
  notes       LessonNote[]
  discussions Discussion[]

  // Phase 17 — AI recommendations pointing back at this lesson
  aiRecommendations AiRecommendation[]

  @@index([chapterId])
  @@index([type])
  @@map("lessons")
}

// =========================================================
// CONTENT
// =========================================================

model TheoryContent {
  id                  String      @id @default(cuid())
  lessonId            String      @unique
  overview            String
  objectives          Json
  contentType         ContentType
  contentUrl          String
  duration            Int?
  completionThreshold Float       @default(0.8)
  // Phase 10: TipTap JSON ProseMirror document for the rich-text body
  // shown alongside the uploaded SCORM/Video/PDF. Nullable for backward
  // compat with legacy theory contents that only had a contentUrl.
  body                Json?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  lesson        Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  videoProgress VideoProgress[]

  @@map("theory_contents")
}

model PracticeContent {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  introduction    String
  objectives      Json
  webglUrl        String
  scoringConfig   Json
  safetyChecklist Json
  passScore       Int
  timeLimit       Int?
  maxAttempts     Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson   Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts PracticeAttempt[]

  @@map("practice_contents")
}

model LessonAttachment {
  id        String   @id @default(cuid())
  lessonId  String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_attachments")
}

// =========================================================
// ASSESSMENT
// =========================================================

model QuestionBank {
  id            String       @id @default(cuid())
  courseId      String?
  departmentId  String?
  question      String
  type          QuestionType
  options       Json
  correctAnswer Json
  explanation   String?
  difficulty    Difficulty   @default(MEDIUM)
  tags          String[]
  points        Int          @default(1)
  createdBy     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  course        Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  creator       User           @relation("QuestionBankAuthor", fields: [createdBy], references: [id])
  quizQuestions QuizQuestion[]

  @@index([courseId])
  @@index([departmentId])
  @@index([createdBy])
  @@index([type])
  @@index([difficulty])
  @@map("question_bank")
}

model Quiz {
  id               String   @id @default(cuid())
  lessonId         String
  title            String
  timeLimit        Int?
  shuffleQuestions Boolean  @default(false)
  showAnswerAfter  Boolean  @default(true)
  passScore        Int
  maxAttempts      Int      @default(3)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([lessonId])
  @@map("quizzes")
}

model QuizQuestion {
  id         String @id @default(cuid())
  quizId     String
  questionId String
  order      Int    @default(0)
  points     Int

  quiz     Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionId])
  @@index([quizId])
  @@index([questionId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  studentId   String
  score       Int
  maxScore    Int
  answers     Json
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  quiz    Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id])

  @@index([quizId])
  @@index([studentId])
  @@map("quiz_attempts")
}

// =========================================================
// PROGRESS
// =========================================================

model CourseEnrollment {
  id              String    @id @default(cuid())
  courseId        String
  studentId       String
  enrolledAt      DateTime  @default(now())
  completedAt     DateTime?
  // Phase 15 — denormalised rollup of LessonProgress so /student/:id/courses
  // can answer in one query without recalculating from the lesson table
  // every request. Updated by ProgressService.calculateCourseProgress
  // after any COMPLETED / quiz-pass / practice-pass cascade.
  progressPercent Int       @default(0)
  // Last time the student did anything in this course (lesson view, quiz
  // attempt, practice attempt). Drives the "inactive > 5 days" at-risk
  // rule + the heatmap activity feed.
  lastActiveAt    DateTime  @default(now())

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id])

  @@unique([courseId, studentId])
  @@index([studentId])
  @@index([lastActiveAt])
  @@map("course_enrollments")
}

model LessonProgress {
  id          String         @id @default(cuid())
  lessonId    String
  studentId   String
  status      ProgressStatus @default(NOT_STARTED)
  score       Int?
  timeSpent   Int            @default(0)
  attempts    Int            @default(0)
  lastViewAt  DateTime       @default(now())
  completedAt DateTime?

  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id])

  @@unique([lessonId, studentId])
  @@index([studentId])
  @@map("lesson_progress")
}

model PracticeAttempt {
  id                    String         @id @default(cuid())
  practiceContentId     String
  studentId             String
  score                 Int
  maxScore              Int
  actions               Json
  violations            Json
  duration              Int
  status                ProgressStatus @default(IN_PROGRESS)
  completedAt           DateTime?
  createdAt             DateTime       @default(now())
  // Phase 15 — fast flag for "student committed a critical safety
  // violation in this attempt". The full detail stays in the JSON
  // `violations` column; this scalar is what the at-risk detector
  // indexes on, so a single WHERE clause across thousands of attempts
  // doesn't have to open + parse every JSON blob.
  hasCriticalViolation  Boolean        @default(false)

  practiceContent PracticeContent @relation(fields: [practiceContentId], references: [id], onDelete: Cascade)
  student         User            @relation(fields: [studentId], references: [id])

  @@index([practiceContentId, studentId])
  @@index([studentId])
  @@index([studentId, hasCriticalViolation])
  @@map("practice_attempts")
}

model VideoProgress {
  id              String   @id @default(cuid())
  theoryContentId String
  studentId       String
  watchedSeconds  Int      @default(0)
  duration        Int
  lastPosition    Int      @default(0)
  isCompleted     Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  theoryContent TheoryContent @relation(fields: [theoryContentId], references: [id], onDelete: Cascade)
  student       User          @relation(fields: [studentId], references: [id])

  @@unique([theoryContentId, studentId])
  @@index([studentId])
  @@map("video_progress")
}

// =========================================================
// CERTIFICATE
// =========================================================

model CertificateCriteria {
  id                String   @id @default(cuid())
  courseId          String   @unique
  minPassScore      Int      @default(70)
  minProgress       Int      @default(100)
  requiredLessons   String[] @default([])
  minPracticeScore  Int      @default(0)
  noSafetyViolation Boolean  @default(true)
  validityMonths    Int?
  customCriteria    Json?
  // Phase 16 — grade thresholds as a JSON map so the instructor can
  // tweak "Xuất sắc / Giỏi / Đạt" per course without a schema change.
  // Default: {"excellent":90,"good":80,"pass":70}. Read by
  // CertificatesService.calculateGrade on issuance.
  gradeThresholds   Json     @default("{\"excellent\":90,\"good\":80,\"pass\":70}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("certificate_criteria")
}

model Certificate {
  id            String            @id @default(cuid())
  studentId     String
  courseId      String
  code          String            @unique
  status        CertificateStatus @default(ACTIVE)
  issuedAt      DateTime          @default(now())
  expiresAt     DateTime?
  revokedAt     DateTime?
  revokedReason String?
  // Phase 16 — snapshot of the grade + score at issuance time. We never
  // recompute these (the student's ongoing quiz attempts shouldn't
  // affect their already-awarded grade), so store them as plain scalars.
  grade         String? // "Xuất sắc" | "Giỏi" | "Đạt"
  finalScore    Int?    // 0..100 — percent used for the grade calc
  // Phase 16 — MinIO key (not a full URL; we re-sign on each GET
  // /certificates/:id/download so students can share links that don't
  // expire awkwardly mid-browser-session).
  pdfUrl        String?

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@index([studentId])
  @@index([courseId])
  @@index([code])
  @@map("certificates")
}

// =========================================================
// SYSTEM (logs, audit, notifications)
// =========================================================

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String
  userAgent String
  success   Boolean
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_logs")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  targetType String
  targetId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// =========================================================
// SYSTEM SETTINGS (Phase 09)
// =========================================================
// Key-value store cho cấu hình runtime: org branding, SMTP,
// security policy, storage limits. Mỗi key là 1 row nên có thể
// audit diff per key và thêm setting mới không cần migration.
// Whitelist key được enforce ở service layer (system-settings).

model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

// =========================================================
// STUDENT DASHBOARD & LEARNING EXPERIENCE (Phase 14)
// =========================================================
// - LessonNote: per-student rich-text notes per lesson (TipTap JSON)
// - Discussion + DiscussionReply: per-lesson Q&A threads with soft delete
// - StudentXP: lifetime XP + computed level for the gamification overlay

model LessonNote {
  id        String   @id @default(cuid())
  lessonId  String
  studentId String
  content   Json // ProseMirror JSON — same shape TheoryContent.body uses
  updatedAt DateTime @updatedAt

  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id])

  @@unique([lessonId, studentId])
  @@map("lesson_notes")
}

model Discussion {
  id        String   @id @default(cuid())
  lessonId  String
  authorId  String
  content   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson  Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  author  User              @relation("DiscussionAuthor", fields: [authorId], references: [id])
  replies DiscussionReply[]

  @@index([lessonId])
  @@index([authorId])
  @@map("discussions")
}

model DiscussionReply {
  id           String   @id @default(cuid())
  discussionId String
  authorId     String
  content      String
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author     User       @relation("DiscussionReplyAuthor", fields: [authorId], references: [id])

  @@index([discussionId])
  @@map("discussion_replies")
}

model StudentXP {
  id        String   @id @default(cuid())
  studentId String   @unique
  totalXP   Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id])

  @@map("student_xp")
}

// =========================================================
// AI LEARNING ASSISTANT (Phase 17)
// =========================================================
// - AiRecommendation: adaptive "review this lesson / practice more /
//   safety reminder" cards surfaced on /student/dashboard. Generated by
//   a daily BullMQ cron via Gemini text model; isRead gates whether the
//   card is still shown.
// - AiChatMessage: transcript of the floating chat widget. `sessionId`
//   groups turns in one conversation; `rating` lets students thumbs-up /
//   down an AI reply for later fine-tuning.
// - AiQuotaLog: per-day counter of requests per Gemini model so the
//   admin health dashboard can show "X/1500 today" without hitting the
//   provider's quota endpoint.
// - AiSuggestedQuestions: 24h cache of Gemini-generated question chips
//   per lesson so every open doesn't re-spend quota.

model AiRecommendation {
  id        String   @id @default(cuid())
  studentId String
  type      String   // "REVIEW_LESSON" | "PRACTICE_MORE" | "SAFETY_REMINDER" | "ADAPTIVE"
  content   String
  lessonId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  student User    @relation(fields: [studentId], references: [id])
  lesson  Lesson? @relation(fields: [lessonId], references: [id])

  @@index([studentId, isRead])
  @@map("ai_recommendations")
}

model AiChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  studentId String
  lessonId  String?
  role      String   // "user" | "model"
  content   String
  rating    Int?     // 1 = thumbs-up, -1 = thumbs-down, null = untouched
  createdAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id])

  @@index([sessionId])
  @@index([studentId, lessonId])
  @@map("ai_chat_messages")
}

model AiQuotaLog {
  id        String   @id @default(cuid())
  date      String   // "YYYY-MM-DD" (UTC) — composite key with model
  model     String   // "chat" | "lite" | "embedding" | raw model id
  requests  Int      @default(0)
  tokens    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([date, model])
  @@map("ai_quota_logs")
}

model AiSuggestedQuestions {
  lessonId  String   @id
  questions Json     // string[] — up to 5 items
  updatedAt DateTime @updatedAt

  @@map("ai_suggested_questions")
}
